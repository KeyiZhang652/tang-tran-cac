name: 自动更新照片清单
on:
  push:
    paths:
      - "photos/**"
      - "!photos/manifest.json"
  workflow_dispatch:

permissions:
  contents: write

jobs:
  manifest:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - name: 重新生成照片清单
        run: python3 scripts/gen_manifest.py
      - name: 提交变化（如有）
        run: |
          if ! git diff --quiet photos/manifest.json; then
            git config user.name "github-actions[bot]"
            git config user.email "github-actions[bot]@users.noreply.github.com"
            git add photos/manifest.json
            git commit -m "自动更新照片清单"
            git push
          fi
